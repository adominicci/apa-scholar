{
  "name": "apa-writer",
  "productName": "APA Scholar",
  "version": "0.1.0",
  "description": "Local-first academic writing workspace for APA-compliant papers.",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "dev": "npm run rebuild:native && electron-forge start",
    "start": "npm run dev",
    "build": "npm run clean && npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "clean": "rm -rf .vite out playwright-report test-results",
    "package": "npm run rebuild:native && electron-forge package",
    "make": "npm run rebuild:native && electron-forge make",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "rebuild:native:node": "npm rebuild better-sqlite3",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "npm run rebuild:native:node && vitest run",
    "test:e2e": "npm run rebuild:native && npm run build && playwright test",
    "postinstall": "npm run rebuild:native"
  },
  "keywords": [
    "electron",
    "react",
    "apa",
    "desktop"
  ],
  "author": {
    "name": "Andres Dominicci",
    "email": "adominicci@misolutionspr.com"
  },
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "electron-squirrel-startup": "^1.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.37.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "40.8.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
